generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id Int @id @default(autoincrement())

    login    String  @unique
    name     String
    password String
    salt     String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model WireguardServer {
    id   Int    @id @default(autoincrement())
    name String @unique

    description String

    baseUrl  String
    apiToken String

    peers WireguardPeer[]
}

model WireguardPeer {
    id Int @id @default(autoincrement())

    wgPeerId   Int
    peerName   String
    publicKey  String
    privateKey String
    address    String
    status     WgPeerStatus @default(ACTIVE)

    lastActivity  DateTime?
    receivedBytes Int       @default(0)
    sendBytes     Int       @default(0)

    createdAt DateTime @default(now())

    client   Client @relation(fields: [clientId], references: [id])
    clientId Int    @unique

    monthlyStats PeerMonthlyStats[]

    wireguardServer   WireguardServer? @relation(fields: [wireguardServerId], references: [id])
    wireguardServerId Int

    @@unique([wireguardServerId, wgPeerId])
}

model Client {
    id          Int     @id @default(autoincrement())
    name        String
    description String
    balance     Int     @default(0)
    isFree      Boolean @default(false)
    tariff      Int     @default(0)

    createdAt DateTime @default(now())

    accessTokenId   String? @unique
    accessTokenHash String?

    peer                WireguardPeer?
    balanceTransactions BalanceTransaction[]
}

model BalanceTransaction {
    id Int @id @default(autoincrement())

    amount Int
    type   TransactionType

    client   Client @relation(fields: [clientId], references: [id])
    clientId Int

    createdAt DateTime @default(now())
}

//Модель для учета трафика по месяцам
model PeerMonthlyStats {
    id    Int      @id @default(autoincrement())
    month DateTime

    peerId Int
    peer   WireguardPeer @relation(fields: [peerId], references: [id])

    receivedBytes BigInt
    sendBytes     BigInt

    createdAt DateTime @default(now())
}

enum WgPeerStatus {
    ACTIVE
    INACTIVE
}

enum TransactionType {
    TOP_UP
    DAILY_CHARGE
}
